# ── Core ──────────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://mongodb:27017          # use container name inside Docker
DB_NAME=ziyanisa
CORS_ORIGINS=https://ziyanisa.bilionsales.com
ENVIRONMENT=production                     # MUST be "production" on Hetzner
JWT_SECRET=                                # generate: openssl rand -hex 32

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PHONE=8341372666                     # 10-digit, no country code

# ── Email OTP (SMTP) ──────────────────────────────────────────────────────────
# Option A: Gmail app password (free, 500/day)
#   1. Enable 2FA on Gmail
#   2. Google Account → Security → App Passwords → generate
#   3. Use that 16-char password here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx             # Gmail app password (no spaces in actual value)
SMTP_FROM=noreply@ziyanisa.bilionsales.com

# Option B: Brevo (formerly Sendinblue) — 300 free emails/day
#   Sign up at brevo.com → SMTP & API → SMTP tab → copy host/user/pass
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-brevo-smtp-key

# Option C: Resend.com — 3000 free emails/month
#   Sign up at resend.com → API Keys → Create → use SMTP bridge
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxx

# ── SMS OTP (India) — 2factor.in ─────────────────────────────────────────────
# Sign up at https://2factor.in → Dashboard → API → copy key
# No template registration needed. OTP SMS sent instantly.
TWOFACTOR_API_KEY=                         # paste your 2factor.in API key here

# ── Payment providers (optional) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── AI / Vision ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434
VISION_MODEL=moondream

# ── Google Drive image storage ────────────────────────────────────────────────
# 1. console.cloud.google.com → New project → Enable "Google Drive API"
# 2. IAM → Service Accounts → Create → Download JSON key
# 3. In Google Drive: create folder "ZiyaNisa Images" → Share with service account email (Editor)
# 4. Copy folder ID from Drive URL: drive.google.com/drive/folders/<THIS_PART>
GDRIVE_SA_JSON={"type":"service_account",...}   # paste entire JSON on one line
GDRIVE_FOLDER_ID=                               # folder ID from Drive URL

# ── GitHub Integration (Bug Reports → auto-create Issues) ─────────────────────
# PAT needs: repo → issues (write) scope on ziyanisa repo
GITHUB_TOKEN=ghp_...
GITHUB_REPO=alitheone007/ziyanisa

# ── Bilion Router ─────────────────────────────────────────────────────────────
# Used by the /router container for multi-brand WhatsApp AI routing
ROUTER_DB_NAME=bilion_router
SESSION_TTL_HOURS=24
