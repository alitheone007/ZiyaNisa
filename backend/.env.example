# ── Core ──────────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=ziyanisa
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development          # set to "production" on Hetzner
JWT_SECRET=change-this-in-prod   # generate: openssl rand -hex 32

# ── Payment providers ─────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=

# ── WhatsApp / Messaging (Twilio) ─────────────────────────────────────────────
# Sign up at twilio.com, enable WhatsApp on your virtual number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886   # your Twilio WA number

# ── AI / Clawbot ──────────────────────────────────────────────────────────────
# Option A: call Anthropic directly from n8n (recommended)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: if clawbot exposes a local REST API on the server
# SSH to server, run: docker ps | grep -i claw
# then: curl http://localhost:CLAWBOT_PORT/
CLAWBOT_URL=http://localhost:3001     # replace with actual port
CLAWBOT_API_KEY=                      # if clawbot requires auth

# ── n8n (running on Hetzner) ─────────────────────────────────────────────────
# n8n webhook base URL for ZiyaNisa workflow
N8N_WEBHOOK_URL=http://localhost:5678   # internal Docker URL
N8N_API_KEY=                            # set in n8n settings → API → Create key
