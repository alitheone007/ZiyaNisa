# ── Core ──────────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://mongodb:27017          # use container name inside Docker
DB_NAME=ziyanisa
CORS_ORIGINS=https://ziyanisa.bilionsales.com
ENVIRONMENT=production                     # MUST be "production" on Hetzner
JWT_SECRET=                                # generate: openssl rand -hex 32

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_PHONE=8341372666                     # 10-digit, no country code

# ── Email OTP (SMTP) ──────────────────────────────────────────────────────────
# Option A: Gmail app password (free, 500/day)
#   1. Enable 2FA on Gmail
#   2. Google Account → Security → App Passwords → generate
#   3. Use that 16-char password here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx             # Gmail app password (no spaces in actual value)
SMTP_FROM=noreply@ziyanisa.bilionsales.com

# Option B: Brevo (formerly Sendinblue) — 300 free emails/day
#   Sign up at brevo.com → SMTP & API → SMTP tab → copy host/user/pass
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-brevo-smtp-key

# Option C: Resend.com — 3000 free emails/month
#   Sign up at resend.com → API Keys → Create → use SMTP bridge
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxx

# ── SMS OTP (India) ───────────────────────────────────────────────────────────
# Fast2SMS — cheapest option (~₹0.10–0.30/msg), free trial credits on signup
#   Sign up at fast2sms.com → Dev section → API Key
SMS_PROVIDER=fast2sms                      # options: fast2sms | 2factor | msg91
SMS_API_KEY=                               # paste your Fast2SMS API key here
SMS_SENDER_ID=ZIYANA

# 2Factor.in — alternative (simple, pay-as-you-go)
# SMS_PROVIDER=2factor
# SMS_API_KEY=your-2factor-api-key

# MSG91 — enterprise (needs DLT template registration with TRAI)
# SMS_PROVIDER=msg91
# SMS_API_KEY=your-msg91-authkey
# MSG91_TEMPLATE_ID=your-dlt-template-id

# ── WhatsApp (optional, via n8n on Hetzner) ───────────────────────────────────
# If your n8n has an OTP webhook workflow, put its URL here.
# SMS is tried first; WhatsApp fires as fallback or background parallel.
N8N_OTP_WEBHOOK=                           # e.g. http://n8n:5678/webhook/otp

# ── Payment providers (optional) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── AI / Vision ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434
VISION_MODEL=moondream

# ── Bilion Router ─────────────────────────────────────────────────────────────
# Used by the /router container for multi-brand WhatsApp AI routing
ROUTER_DB_NAME=bilion_router
SESSION_TTL_HOURS=24
