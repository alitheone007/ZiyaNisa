# ── MongoDB ───────────────────────────────────────────────────────────────────
# In docker-compose: use the service name as host
MONGO_URL=mongodb://mongodb:27017
DB_NAME=ziyanisa

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Add your subdomain here.
# Example: https://app.yourdomain.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Payment providers (leave blank until integrated) ─────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=
PAYTM_INDUSTRY_TYPE=

# ── GitHub Container Registry (set by CI — do not change) ────────────────────
# GITHUB_REPOSITORY is set automatically by GitHub Actions

# ── SSL / Domain ──────────────────────────────────────────────────────────────
# DOMAIN=app.yourdomain.com          # your GoDaddy subdomain
# LETSENCRYPT_EMAIL=you@email.com    # for certbot notifications
