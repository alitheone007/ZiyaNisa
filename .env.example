# ── MongoDB ───────────────────────────────────────────────────────────────────
# In docker-compose: use the service name as host
MONGO_URL=mongodb://mongodb:27017
DB_NAME=ziyanisa

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production                # "development" locally
JWT_SECRET=change-this-in-prod        # openssl rand -hex 32

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Frontend env vars (REACT_APP_ prefix required by CRA) ────────────────────
# These are baked in at build time — rebuild frontend after changing these
REACT_APP_API_URL=https://yourdomain.com/api
REACT_APP_WA_NUMBER=919000000000     # Twilio WA number — see n8n/SETUP.md

# ── WhatsApp / Twilio ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886   # your Twilio WA number with +

# ── AI / Clawbot ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAWBOT_URL=http://localhost:3001     # check on server: docker ps | grep claw

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=change-in-prod    # openssl rand -hex 32
N8N_API_KEY=                          # n8n Settings → API → Create key

# ── Payment providers (leave blank until integrated) ─────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=

# ── SSL / Domain ──────────────────────────────────────────────────────────────
DOMAIN=app.yourdomain.com             # your GoDaddy subdomain → 95.216.150.181
LETSENCRYPT_EMAIL=you@email.com       # for certbot notifications
