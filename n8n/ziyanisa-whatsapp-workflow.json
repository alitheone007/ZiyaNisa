    {
      "parameters": {
        "jsCode": "// Decide whether this text message is an address, order ID, or a chat message\nconst msg = $('Parse Variables').first().json.message_body || '';\nconst msgLower = msg.toLowerCase();\n\n// Check if it looks like an order ID\nconst isOrderId = /ord[-]?\\w{4,}/i.test(msg);\n\n// Check if it looks like a delivery address (has numbers + city/state keywords)\nconst hasNumbers = /\\d{3,}/.test(msg);\nconst addressKeywords = ['pincode', 'flat', 'house', 'road', 'street', 'nagar', 'colony', 'layout', 'hyderabad', 'bangalore', 'mumbai', 'delhi', 'chennai', 'pune', 'kolkata'];\nconst hasAddressKw = addressKeywords.some(k => msgLower.includes(k));\nconst isPossibleAddress = msg.length > 20 && hasNumbers && hasAddressKw;\n\nreturn [{ json: { is_order_id: isOrderId, is_address: isPossibleAddress, pass_to_ai: true } }];"
      },
